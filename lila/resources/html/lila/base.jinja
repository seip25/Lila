<!DOCTYPE html>
<html lang="{{ lang }}" data-theme="light">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="color-scheme" content="light dark" />
  <meta http-equiv="X-UA-Compatible" content="ie=edge" />
  <meta name="description" content="{{ description }}" />
  <meta name="keywords" content="{{ keywords }}" />
  <meta name="author" content="{{ author }}" />
  <title>{% block title %}{{ title }}{% endblock %}</title>
  <link rel="icon" type="image/x-icon" href="{{ public('img/lila.png') }}" />
  <!-- Google Fonts for Outfit and Inter -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">

 
  {{ public('js/tailwind.js') | safe }}
  {% block head %}{% endblock %}
</head>

<body
  class="min-h-screen bg-bg-body dark:bg-bg-body-dark text-slate-800 dark:text-slate-200 transition-colors duration-300 font-sans flex flex-col">
  {% block content %}{% endblock %}

  <script src="{{public('js/utils.js')}}"></script>
  {% block scripts %}{% endblock %}
</body>

</html>